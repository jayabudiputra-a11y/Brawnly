/*
  # ──────────────────────────────────────────────────────────────────────────
  # Netlify server-side HTTP headers (public/_headers)
  # Dibaca oleh Netlify CDN — berlaku sebelum HTML dikirim ke browser.
  # CSP di sini adalah PELENGKAP meta-tag CSP di adblocker.ts.
  # ──────────────────────────────────────────────────────────────────────────

  Content-Security-Policy: default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: *; frame-src 'self' blob: data: https://www.youtube.com https://player.vimeo.com https://vimeo.com https://accounts.google.com https://www.google.com https://*.google.com https://fundingchoices.google.com https://td.doubleclick.net https://www.instagram.com https://instagram.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' * blob:; connect-src 'self' * blob: data:; img-src 'self' data: blob: *; font-src 'self' data: *; style-src 'self' 'unsafe-inline' *
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  X-XSS-Protection: 1; mode=block
